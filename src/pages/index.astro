---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Nativa Service - Governança e Estratégia Ambiental">
  <main>
    <!--  Section -->
    <section class="hero">
      <div class="hero-bg-image"></div>
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <h1 class="logo-text gsap-reveal">
          NATIVA <span class="accent">SERVICE</span>
        </h1>
        <h2 class="gsap-reveal-delay">Governança e Estratégia Ambiental</h2>
        <div class="cta-wrapper gsap-reveal-delay-2">
          <a href="#contato" class="btn">Fale Conosco</a>
          <a href="#sobre" class="btn btn-outline">Conheça a Nativa</a>
        </div>
      </div>
    </section>

    <!-- Sobre Nós -->
    <section id="sobre" class="about section-padding">
      <div class="container about-panel">
        <h2 class="section-title">A Nativa</h2>
        <p class="about-text">
          <p>
            A Nativa nasceu para transformar desafios ambientais em decisões
            estratégicas. <br />Atuamos com foco em resultado, garantindo
            segurança regulatória, eficiência operacional e suporte técnico para
            empresas que precisam avançar com confiança.
          </p>

          <p>
            Nosso compromisso é entregar previsibilidade, redução de riscos e
            fortalecimento da gestão ambiental, contribuindo para decisões mais
            seguras, sustentáveis e estratégicas.
          </p>
        </p>

        <blockquote class="slogan">
          "Origem que estrutura. Estratégia que perpetua."
        </blockquote>
      </div>
    </section>

    <!-- Pilares de Atuação -->
    <section id="servicos" class="services section-padding">
      <div class="container">
        <h2 class="section-title">Pilares Estratégicos</h2>
        <div class="grid-services">
          <!-- Governança -->
          <a
            href="/servicos?service=governanca-ambiental"
            class="service-card glass-panel"
          >
            <div class="service-icon-wrapper">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                ></path><path d="m9 12 2 2 4-4"></path></svg
              >
            </div>
            <h3>Governança Ambiental</h3>
            <p>
              Condução segura e estratégica de obrigações ambientais, promovendo
              controle e previsibilidade.
            </p>
            <div class="service-card-footer">
              <span class="btn-more-card"
                >Saiba mais <span class="arrow">→</span></span
              >
            </div>
          </a>
          <!-- ESG -->
          <a href="/servicos?service=esg" class="service-card glass-panel">
            <div class="service-icon-wrapper">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><path
                  d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"
                ></path><path d="M2 12h20"></path></svg
              >
            </div>
            <h3>Governança - ESG</h3>
            <p>
              Integração das práticas ambientais às estratégias corporativas,
              com comitês e indicadores ESG.
            </p>
            <div class="service-card-footer">
              <span class="btn-more-card"
                >Saiba mais <span class="arrow">→</span></span
              >
            </div>
          </a>
          <!-- Estratégia Regulatória -->
          <a
            href="/servicos?service=estrategia"
            class="service-card glass-panel"
          >
            <div class="service-icon-wrapper">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"
                ></path><circle cx="12" cy="10" r="3"></circle></svg
              >
            </div>
            <h3>Estratégia Regulatória</h3>
            <p>
              Gestão de licenciamento e antecipação de riscos em processos
              ambientais (LI, LO, LAC).
            </p>
            <div class="service-card-footer">
              <span class="btn-more-card"
                >Saiba mais <span class="arrow">→</span></span
              >
            </div>
          </a>
          <!-- Estruturação -->
          <a
            href="/servicos?service=processos"
            class="service-card glass-panel"
          >
            <div class="service-icon-wrapper">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M20 7h-9"></path><path d="M14 17H5"></path><circle
                  cx="17"
                  cy="17"
                  r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg
              >
            </div>
            <h3>Estruturação de Processos</h3>
            <p>
              Mapeamento e otimização da gestão de rotinas, papéis e
              condicionantes ambientais.
            </p>
            <div class="service-card-footer">
              <span class="btn-more-card"
                >Saiba mais <span class="arrow">→</span></span
              >
            </div>
          </a>
          <!-- Inteligência -->
          <a
            href="/servicos?service=territorial"
            class="service-card glass-panel"
          >
            <div class="service-icon-wrapper">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                ></path><circle cx="12" cy="10" r="3"></circle></svg
              >
            </div>
            <h3>Inteligência Territorial</h3>
            <p>
              Uso de geotecnologia e sensoriamento remoto para análise espacial
              e apoio à decisão.
            </p>
            <div class="service-card-footer">
              <span class="btn-more-card"
                >Saiba mais <span class="arrow">→</span></span
              >
            </div>
          </a>
          <!-- Conformidade -->
          <a
            href="/servicos?service=conformidade"
            class="service-card glass-panel"
          >
            <div class="service-icon-wrapper">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                ></path><path d="M12 8v4"></path><path d="M12 16h.01"
                ></path></svg
              >
            </div>
            <h3>Conformidade Ambiental</h3>
            <p>
              Auditorias e adequação legal, fortalecendo a segurança jurídica do negócio.
            </p>
            <div class="service-card-footer">
              <span class="btn-more-card"
                >Saiba mais <span class="arrow">→</span></span
              >
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Resultados -->
    <section class="results section-padding bg-dark">
      <div class="container">
        <h2 class="section-title text-light">Resultados Entregues</h2>
        <div class="stats-grid">
          <div class="stat-item">
            <span class="stat-number">451</span>
            <span class="stat-label">Processos Conduzidos junto aos órgãos Ambientais</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">R$ 600k+</span>
            <span class="stat-label">Economia em Multas</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">1951</span>
            <span class="stat-label">Requisitos Atendidos</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">100+</span>
            <span class="stat-label">Autorizações e Declarações Entregues</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Contato -->
    <section id="contato" class="contact section-padding">
      <div class="container text-center">
        <h2 class="section-title">
          Pronto para transformar sua gestão ambiental?
        </h2>
        <p class="about-text" style="margin-bottom: 2rem;">
          Entre em contato com a equipe da Nativa Service e descubra como
          podemos agregar valor sustentável ao seu negócio.
        </p>
        <a href="mailto:contato@nativaservice.com" class="btn"
          >Fale com um Especialista</a
        >
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Local Styles to make it look premium */
  .section-padding {
    padding: 8rem 0;
  }
  .bg-dark {
    background-color: var(--color-primary);
  }
  .text-light {
    color: var(--color-text-light);
  }
  .text-center {
    text-align: center;
  }

  /* Hero */
  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #122119; /* Fallback dark green */
    background-image: url("/images/identidadeVisual/heroImage-nativaService.jpeg");
    background-size: cover;
    background-position: center; /* Bom para mobile */
    z-index: -2;
  }
  @media (min-width: 992px) {
    .hero-bg-image {
      background-position: center -800px; /* Ajuste aqui para Desktop */
    }
  }
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    /* Premium dark gradient overlay */
    background: linear-gradient(
      to bottom,
      rgba(18, 33, 25, 0.5) 0%,
      rgba(18, 33, 25, 0.8) 100%
    );
    z-index: -1;
  }
  .hero-content {
    text-align: center;
    color: var(--color-text-light);
  }
  .logo-text {
    font-size: 5rem;
    letter-spacing: 2px;
    margin-bottom: 1rem;
  }
  .accent {
    color: var(--color-accent);
  }
  .hero h2 {
    font-size: 1.8rem;
    font-weight: 300;
    margin-bottom: 3rem;
    opacity: 0.9;
  }
  .cta-wrapper {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  /* About */
  .about-panel {
    padding: 4rem;
    text-align: center;
  }
  .section-title {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: var(--color-primary);
    text-align: center;
  }
  .bg-dark .section-title {
    color: var(--color-text-light);
  }
  .about-text {
    font-size: 1.2rem;
    max-width: 800px;
    margin: 0 auto 1.5rem auto;
    color: #444;
  }
  .slogan {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 3rem;
    font-style: italic;
  }

  /* Services Grid */
  .grid-services {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
  }
  .service-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2.5rem;
    text-decoration: none;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }
  .service-card:hover {
    transform: translateY(-8px);
    background: #fff;
    border-color: var(--color-accent);
    box-shadow: 0 20px 40px rgba(30, 59, 42, 0.08);
  }
  .service-icon-wrapper {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    background: rgba(30, 59, 42, 0.05);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all 0.4s ease;
  }
  .service-card:hover .service-icon-wrapper {
    background: var(--color-primary);
    color: var(--color-accent);
    transform: scale(1.05);
  }
  .service-card h3 {
    color: var(--color-primary);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    transition: color 0.3s ease;
  }
  .service-card:hover h3 {
    color: var(--color-accent);
  }
  .service-card p {
    color: #555;
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    flex-grow: 1;
  }
  .service-card-footer {
    width: 100%;
    display: flex;
    justify-content: flex-start;
    margin-top: auto;
  }
  .btn-more-card {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
  }
  .btn-more-card .arrow {
    transition: transform 0.3s ease;
  }
  .service-card:hover .btn-more-card {
    color: var(--color-primary);
  }
  .service-card:hover .btn-more-card .arrow {
    transform: translateX(4px);
  }

  /* Results */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: center;
    margin-top: 4rem;
  }
  .stat-number {
    display: block;
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .stat-label {
    font-size: 1.1rem;
    color: var(--color-text-light);
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .logo-text {
      font-size: 2.8rem;
    }
    .hero h2 {
      font-size: 1.2rem;
      margin-bottom: 2rem;
    }
    .cta-wrapper {
      flex-direction: column;
      gap: 1rem;
      align-items: stretch;
    }
    .section-padding {
      padding: 4rem 0;
    }
    .about-panel {
      padding: 2rem 1.5rem;
    }
    .section-title {
      font-size: 2rem;
    }
    .slogan {
      font-size: 1.3rem;
      margin-top: 2rem;
    }
    .stat-number {
      font-size: 2.8rem;
    }
  }
</style>

<script>
  // Setup GSAP Animations
  document.addEventListener("DOMContentLoaded", () => {
    // The gsap global is injected via is:inline from the CDN in Layout.astro
    if (typeof (window as any).gsap !== "undefined") {
      const gsap = (window as any).gsap;

      gsap.from(".gsap-reveal", {
        y: 50,
        opacity: 0,
        duration: 1,
        ease: "power3.out",
      });
      gsap.from(".gsap-reveal-delay", {
        y: 50,
        opacity: 0,
        duration: 1,
        delay: 0.3,
        ease: "power3.out",
      });
      gsap.from(".gsap-reveal-delay-2", {
        y: 50,
        opacity: 0,
        duration: 1,
        delay: 0.6,
        ease: "power3.out",
      });

      // Scroll animations
      gsap.utils.toArray(".service-card").forEach((card: any, i: number) => {
        gsap.from(card, {
          scrollTrigger: {
            trigger: card,
            start: "top bottom-=100",
            toggleActions: "play none none reverse",
          },
          y: 50,
          opacity: 0,
          duration: 0.8,
          delay: (i % 3) * 0.1, // staggering based on row position
          ease: "power2.out",
        });
      });

      gsap.from(".about-panel", {
        scrollTrigger: {
          trigger: ".about-panel",
          start: "top bottom-=150",
        },
        y: 50,
        opacity: 0,
        duration: 1,
        ease: "power3.out",
      });

      gsap.from(".stat-item", {
        scrollTrigger: {
          trigger: ".stats-grid",
          start: "top bottom-=100",
        },
        scale: 0.8,
        opacity: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: "back.out(1.7)",
      });
    }
  });
</script>
