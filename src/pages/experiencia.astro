---
import Layout from '../layouts/Layout.astro';
import HeroAnimation from '../components/HeroAnimation.astro';
---

<Layout title="Nossa Experiência | Nativa Service">
  <div class="page-header">
    <HeroAnimation />
    <div class="container text-center">
      <h1 class="gsap-reveal">Nossa <span class="accent">Experiência</span></h1>
      <p class="subtitle gsap-reveal-delay">Resultados entregues, setores de atuação e parcerias estratégicas.</p>
    </div>
  </div>

  <section class="section-padding bg-dark">
    <div class="container">
      <div class="results-header text-center mb-5">
        <h2 class="section-title text-light">Principais Resultados Alcançados</h2>
      </div>
      
      <div class="results-grid">
        <div class="result-card gsap-fade-up">
          <div class="number">451</div>
          <p>Processos regularizados junto ao órgãos SEMAD, ANA, FEAM, SUPRAM, IEF, IGAM e IBAMA</p>
        </div>
        <div class="result-card gsap-fade-up">
          <div class="number">100+</div>
          <p>Entrega de declarações, 50 autorizações ambientais e 31 licenças de complexidade alta</p>
        </div>
        <div class="result-card gsap-fade-up">
          <div class="number">1951</div>
          <p>Atendimentos a requisitos obrigatórios no Iusnatura</p>
        </div>
        <div class="result-card gsap-fade-up">
          <div class="number">R$ 600k</div>
          <p>Economia em multas e autuações ambientais</p>
        </div>
        
        <div class="result-highlight glass-panel gsap-fade">
          <h3>Estruturações de Destaque</h3>
          <ul>
            <li>Estruturação do LAIA – Levantamento de Aspectos e Impactos Ambientais.</li>
            <li>Estruturação do Plano de Biodiversidade Padrão Bonsucro e ISO 14001.</li>
            <li>Relatório de Sustentabilidade com classificação Razoável (primeira empresa do setor sucroenergético).</li>
            <li>Selo ouro no inventário de GEE por dois anos consecutivos.</li>
            <li>Estruturação do Plano de Transição Climática e Plano Plurianual ESG.</li>
            <li>Nota B no report CDP e Coordenação de Comissão ESG e report ao Ise B3.</li>
            <li>Estruturação de time de sustentabilidade com definição de processos e indicadores.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <h2 class="section-title text-center mb-5">Principais Setores de Atuação</h2>

      <img src="/images/identidadeVisual/logo.svg" style="width: 80px; margin: 20px auto; margin-bottom: 80px; display: block;" alt="Imagem 1" class="w-full h-auto gsap-fade" />
      
      <div class="sectors-grid">
        <div class="sector-card gsap-fade-up">
          <h3>Indústria</h3>
          <p>Apoio à gestão ambiental, licenciamento, conformidade regulatória e gestão de riscos ambientais em operações industriais.</p>
        </div>
        <div class="sector-card gsap-fade-up">
          <h3>Agroindústria</h3>
          <p>Suporte à regularização ambiental, gestão territorial e condução de processos ambientais no setor agroindustrial.</p>
        </div>
        <div class="sector-card gsap-fade-up">
          <h3>Energia</h3>
          <p>Apoio à condução de processos ambientais e gestão regulatória em projetos de geração e infraestrutura energética.</p>
        </div>
        <div class="sector-card gsap-fade-up">
          <h3>Mineração</h3>
          <p>Suporte técnico na gestão ambiental, atendimento às exigências regulatórias e organização de processos ambientais.</p>
        </div>
        <div class="sector-card gsap-fade-up">
          <h3>Infraestrutura</h3>
          <p>Apoio na condução de processos ambientais associados a projetos de infraestrutura e desenvolvimento territorial.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container">
      <h2 class="section-title text-center mb-5">Quem confia em nós</h2>
      
      <div class="partners-wrap">
        <div class="clients-section">
          <h3 class="mb-4" style="color: var(--color-accent); text-align: center;">Nossos Clientes</h3>
          <div class="clients-list gsap-fade">
            <div class="client-logo">
              <img src="/images/clientes/image.png" alt="Cliente 1" class="client-img" />
            </div>
            <div class="client-logo">
              <img src="/images/clientes/image copy.png" alt="POWER Manutenção" class="client-img" />
            </div>
            <div class="client-logo">
              <img src="/images/clientes/image copy 2.png" alt="Fazenda Bela Vista" class="client-img" />
            </div>
          </div>
        </div>

        <div class="partners-section mt-5">
          <h3 class="mb-4" style="color: var(--color-accent); text-align: center;">Nossos Parceiros</h3>
          <div class="partners-grid">
            <div class="partner-card gsap-fade-up">
              <h4>Mayne Veronesi</h4>
              <p>Engenheira Ambiental e Sanitarista, Engenheira de Segurança do Trabalho, Mestre em Tecnologia, Ambiente e Sociedade.</p>
            </div>
            <div class="partner-card gsap-fade-up">
              <h4>AG mapa</h4>
              <p>Empresa especializada em Agrimensura, Geoprocessamento e Levantamentos topográficos.</p>
            </div>
            <div class="partner-card gsap-fade-up">
              <h4>Sonar</h4>
              <p>Consultoria em gestão empresarial by Renata Bertele. Práticas de GRC e ESG.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    position: relative;
    padding: 12rem 0 6rem 0;
    overflow: hidden;
    color: #fff;
  }
  .page-header h1 {
    font-size: 4rem;
    margin-bottom: 1rem;
  }
  .accent { color: var(--color-accent); }
  .subtitle {
    font-size: 1.5rem;
    font-style: italic;
    opacity: 0.9;
  }
  
  .section-padding { padding: 6rem 0; }
  .text-center { text-align: center; }
  .mb-4 { margin-bottom: 2rem; }
  .mb-5 { margin-bottom: 3rem; }
  .mt-5 { margin-top: 4rem; }
  .bg-dark { background-color: var(--color-primary); }
  .bg-light { background-color: #f5f3eb; }
  .text-light { color: var(--color-text-light); }
  
  .section-title {
    font-size: 2.5rem;
    color: var(--color-primary);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }
  .result-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(196, 154, 69, 0.2);
    border-radius: 20px;
    padding: 3rem 2rem;
    text-align: center;
  }
  .result-card .number {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .result-card p {
    color: var(--color-text-light);
    opacity: 0.9;
  }

  .result-highlight {
    grid-column: 1 / -1;
    background: rgba(255,255,255,0.05);
    padding: 3rem;
    margin-top: 2rem;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .result-highlight h3 {
    color: var(--color-accent);
    font-size: 1.8rem;
    margin-bottom: 2rem;
  }
  .result-highlight ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 1.5rem 3rem;
  }
  .result-highlight li {
    color: #fff;
    padding-left: 2rem;
    position: relative;
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .result-highlight li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  @media (max-width: 768px) {
    .result-highlight {
      padding: 2rem 1.5rem;
    }
    .result-highlight h3 {
      font-size: 1.5rem;
    }
    .result-highlight ul {
      grid-template-columns: 1fr;
    }
    .result-highlight li {
      font-size: 0.9rem;
    }
  }

  .sectors-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .sector-card {
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border-top: 4px solid var(--color-accent);
    display: flex;
    flex-direction: column;
    grid-column: span 2; /* All cards take 1/3 of the width (2 out of 6 columns) */
  }

  /* Centering the first two cards on the first row */
  .sector-card:nth-child(1) {
    grid-column: 2 / span 2;
  }
  .sector-card:nth-child(2) {
    grid-column: 4 / span 2;
  }

  @media (max-width: 900px) {
    .sectors-grid {
      grid-template-columns: 1fr;
    }
    .sector-card, .sector-card:nth-child(1), .sector-card:nth-child(2) {
      grid-column: span 1;
    }
  }
  .sector-card h3 {
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .clients-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }
  .client-logo {
    background: #fff;
    padding: 1.5rem 2.5rem;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.05);
  }
  .client-img {
    height: 60px;
    width: auto;
    object-fit: contain;
    mix-blend-mode: multiply; /* Helps remove white backgrounds if any */
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }
  .partner-card {
    background: #fff;
    padding: 2.5rem;
    border-radius: 15px;
    text-align: center;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .partner-card h4 {
    color: var(--color-primary);
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }
  .partner-card p {
    font-size: 0.95rem;
    color: #555;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof (window as any).gsap !== 'undefined') {
      const gsap = (window as any).gsap;
      
      gsap.from(".gsap-reveal", { y: 50, opacity: 0, duration: 1, ease: "power3.out" });
      gsap.from(".gsap-reveal-delay", { y: 50, opacity: 0, duration: 1, delay: 0.3, ease: "power3.out" });

      gsap.utils.toArray('.gsap-fade-up').forEach((elem: any) => {
        gsap.from(elem, {
          scrollTrigger: { trigger: elem, start: "top bottom-=50" },
          y: 40, opacity: 0, duration: 0.8, ease: "power2.out"
        });
      });

      gsap.from('.gsap-fade', {
        scrollTrigger: { trigger: '.gsap-fade', start: "top bottom-=100" },
        opacity: 0, duration: 1
      });
    }
  });
</script>
