---
import Layout from '../layouts/Layout.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nossa Experiência | Nativa Service">
  <div class="page-header">
    <div class="header-bg"></div>
    <div class="header-overlay"></div>
    <div class="container text-center">
      <h1 class="gsap-reveal">Nossa <span class="accent">Experiência</span></h1>
      <p class="subtitle gsap-reveal-delay">Resultados entregues, setores de atuação e parcerias estratégicas.</p>
    </div>
  </div>

  <section class="section-padding bg-dark">
    <div class="container">
      <div class="results-header text-center mb-5">
        <h2 class="section-title text-light">Principais Resultados Alcançados</h2>
      </div>
      
      <div class="results-grid">
        <div class="result-card gsap-fade-up">
          <div class="number">451</div>
          <p>Processos regularizados junto ao órgãos SEMAD, ANA, FEAM, SUPRAM, IEF, IGAM e IBAMA</p>
        </div>
        <div class="result-card gsap-fade-up">
          <div class="number">100+</div>
          <p>Declarações e Autorizações entregues</p>
        </div>
        <div class="result-card gsap-fade-up">
          <div class="number">1951</div>
          <p>Requisitos atendidos no Iusnatura</p>
        </div>
        <div class="result-card gsap-fade-up">
          <div class="number">R$ 600k</div>
          <p>Economia em multas e autuações ambientais</p>
        </div>
        
        <div class="result-highlight glass-panel gsap-fade">
          <h3>Estruturações de Destaque</h3>
          <ul>
            <li>Estruturação do LAIA – Levantamento de Aspectos e Impactos Ambientais.</li>
            <li>Estruturação do Plano de Biodiversidade Padrão Bonsucro e ISO 14001.</li>
            <li>Relatório de Sustentabilidade com classificação Razoável (primeira empresa do setor sucroenergético).</li>
            <li>Selo ouro no inventário de GEE por dois anos consecutivos.</li>
            <li>Estruturação do Plano de Transição Climática e Plano Plurianual ESG.</li>
            <li>Nota B no report CDP e Coordenação de Comissão ESG e report ao Ise B3.</li>
            <li>Estruturação de time de sustentabilidade com definição de processos e indicadores.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container">
      <h2 class="section-title text-center mb-5">Principais Setores de Atuação</h2>

      <img src="/images/identidadeVisual/logo.svg" style="width: 80px; margin: 20px auto; margin-bottom: 80px; display: block;" alt="Imagem 1" class="w-full h-auto gsap-fade" />
      
      <div class="sectors-grid">
        <div class="sector-card gsap-fade-up">
          <h3>Indústria</h3>
          <p>Apoio à gestão ambiental, licenciamento, conformidade regulatória e gestão de riscos ambientais em operações industriais.</p>
        </div>
        <div class="sector-card gsap-fade-up">
          <h3>Agroindústria</h3>
          <p>Suporte à regularização ambiental, gestão territorial e condução de processos ambientais no setor agroindustrial.</p>
        </div>
        <div class="sector-card gsap-fade-up">
          <h3>Energia</h3>
          <p>Apoio à condução de processos ambientais e gestão regulatória em projetos de geração e infraestrutura energética.</p>
        </div>
        <div class="sector-card gsap-fade-up">
          <h3>Mineração</h3>
          <p>Suporte técnico na gestão ambiental, atendimento às exigências regulatórias e organização de processos ambientais.</p>
        </div>
        <div class="sector-card gsap-fade-up">
          <h3>Infraestrutura</h3>
          <p>Apoio na condução de processos ambientais associados a projetos de infraestrutura e desenvolvimento territorial.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-light">
    <div class="container">
      <h2 class="section-title text-center mb-5">Quem confia em nós</h2>
      
      <div class="partners-wrap">
        <div class="clients-section">
          <h3 class="section-subtitle">Nossos Clientes</h3>
          <div class="marquee-container gsap-fade">
            <div class="marquee-content">
              <!-- First set of logos -->
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/crvIndustrial.jpeg" alt="CRV Industrial" class="client-img" /></div></div>
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/jll.webp" alt="JLL" class="client-img" /></div></div>
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/rubi.jpeg" alt="Rubi s.a." class="client-img" /></div></div>
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/fazendaBelaVista.webp" alt="Fazenda Bela Vista" class="client-img" /></div></div>
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/powerManutencao.webp" alt="POWER Manutenção" class="client-img" /></div></div>
              <!-- Duplicate set for seamless loop -->
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/crvIndustrial.jpeg" alt="CRV Industrial" class="client-img" /></div></div>
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/jll.webp" alt="JLL" class="client-img" /></div></div>
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/rubi.jpeg" alt="Rubi s.a." class="client-img" /></div></div>
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/fazendaBelaVista.webp" alt="Fazenda Bela Vista" class="client-img" /></div></div>
              <div class="client-logo-wrap"><div class="client-logo"><img src="/images/clientes/powerManutencao.webp" alt="POWER Manutenção" class="client-img" /></div></div>
            </div>
          </div>
        </div>

        <div class="partners-section mt-5">
          <h3 class="section-subtitle">Nossas Parcerias</h3>
          <div class="partners-grid">
            <div class="partner-card glass-panel gsap-fade-up">
              <div class="partner-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              </div>
              <h4>Mayne Veronesi</h4>
              <p>Engenheira Ambiental e Sanitarista, Engenheira de Segurança do Trabalho, Mestre em Tecnologia, Ambiente e Sociedade.</p>
            </div>
            <div class="partner-card glass-panel gsap-fade-up">
              <div class="partner-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon><line x1="8" y1="2" x2="8" y2="18"></line><line x1="16" y1="6" x2="16" y2="22"></line></svg>
              </div>
              <h4>AG mapa</h4>
              <p>Empresa especializada em Agrimensura, Geoprocessamento e Levantamentos topográficos.</p>
            </div>
            <div class="partner-card glass-panel gsap-fade-up">
              <div class="partner-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              </div>
              <h4>Sonar</h4>
              <p>Consultoria em gestão empresarial by Renata Bertele. Práticas de GRC e ESG.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    position: relative;
    padding: 12rem 0 6rem 0;
    overflow: hidden;
    color: #fff;
    background-color: var(--color-primary);
  }
  .header-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('/images/hero-experiencia.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    z-index: 0;
  }
  .header-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(18, 33, 25, 0.6) 0%, rgba(18, 33, 25, 0.9) 100%);
    z-index: 1;
  }
  .page-header .container {
    position: relative;
    z-index: 2;
  }
  .page-header h1 {
    font-size: 4rem;
    margin-bottom: 1rem;
  }
  .accent { color: var(--color-accent); }
  .subtitle {
    font-size: 1.5rem;
    font-style: italic;
    opacity: 0.9;
  }
  
  .section-title {
    font-size: 3rem;
    color: var(--color-primary);
    margin-bottom: 4rem;
    position: relative;
    display: block;
    width: 100%;
    text-align: center;
  }
  .section-title::after {
    content: '';
    position: absolute;
    bottom: -15px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background: var(--color-accent);
    border-radius: 2px;
  }
  .text-light.section-title::after {
    background: var(--color-accent);
  }

  .section-subtitle {
    color: var(--color-accent);
    text-align: center;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 3rem;
    display: block;
    width: 100%;
  }

  .section-padding { 
    padding: 8rem 0; 
    position: relative;
    z-index: 1;
  }

  .bg-light { 
    background-color: #f5f3eb;
    background-image: radial-gradient(rgba(30, 59, 42, 0.03) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  .bg-dark {
    background-color: var(--color-primary);
    background-image: radial-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }
  .result-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(196, 154, 69, 0.1);
    border-radius: 24px;
    padding: 3.5rem 2rem;
    text-align: center;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
    overflow: hidden;
  }
  .result-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at top right, rgba(196, 154, 69, 0.1), transparent);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .result-card:hover {
    transform: translateY(-10px);
    background: rgba(255,255,255,0.07);
    border-color: var(--color-accent);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .result-card:hover::before {
    opacity: 1;
  }
  .result-card .number {
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 1rem;
    display: block;
    text-shadow: 0 10px 20px rgba(196, 154, 69, 0.2);
  }
  .result-card p {
    color: var(--color-text-light);
    opacity: 0.8;
    font-size: 1rem;
    line-height: 1.5;
  }

  .result-highlight {
    grid-column: 1 / -1;
    background: rgba(255,255,255,0.05);
    padding: 4rem;
    margin-top: 3rem;
    border-radius: 32px;
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    transition: all 0.4s ease;
  }
  .result-highlight:hover {
    border-color: var(--color-accent);
    background: rgba(255,255,255,0.08);
  }
  .result-highlight h3 {
    color: var(--color-accent);
    font-size: 2.2rem;
    margin-bottom: 2.5rem;
    font-weight: 700;
  }
  .result-highlight ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 2rem 4rem;
  }
  .result-highlight li {
    color: #fff;
    padding-left: 2.5rem;
    position: relative;
    line-height: 1.6;
    font-size: 1.05rem;
    opacity: 0.9;
    transition: all 0.3s ease;
  }
  .result-highlight li:hover {
    opacity: 1;
    transform: translateX(5px);
  }
  .result-highlight li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-accent);
    font-weight: bold;
    font-size: 1.2rem;
  }

  @media (max-width: 768px) {
    .result-highlight {
      padding: 2.5rem 1.5rem;
    }
    .result-highlight h3 {
      font-size: 1.8rem;
    }
    .result-highlight ul {
      grid-template-columns: 1fr;
    }
    .result-highlight li {
      font-size: 0.95rem;
    }
  }

  .sectors-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .sector-card {
    background: #fff;
    padding: 3.5rem 2.5rem;
    border-radius: 24px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.03);
    border-top: 5px solid var(--color-accent);
    display: flex;
    flex-direction: column;
    flex: 1 1 320px;
    max-width: 380px;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
  }
  .sector-card:hover {
    transform: translateY(-15px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.1);
    border-top-width: 8px;
  }
  .sector-card::after {
    content: '→';
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    font-size: 1.5rem;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }
  .sector-card:hover::after {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .sector-card {
      flex: 1 1 100%;
      max-width: 100%;
      padding: 2.5rem 2rem;
    }
  }
  .sector-card h3 {
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .marquee-container {
    overflow: hidden;
    padding: 2rem 0;
    position: relative;
    width: 100%;
  }
  .marquee-container::before, .marquee-container::after {
    content: '';
    position: absolute;
    top: 0;
    width: 150px;
    height: 100%;
    z-index: 2;
  }
  .marquee-container::before {
    left: 0;
    background: linear-gradient(to right, #f5f3eb, transparent);
  }
  .marquee-container::after {
    right: 0;
    background: linear-gradient(to left, #f5f3eb, transparent);
  }

  .marquee-content {
    display: flex;
    width: max-content;
    animation: marquee 30s linear infinite;
  }
  .marquee-content:hover {
    animation-play-state: paused;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .client-logo-wrap {
    padding: 0 1.5rem;
  }
  .client-logo {
    background: #fff;
    padding: 1.5rem 2.5rem;
    border-radius: 20px;
    height: 100px;
    width: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.03);
    transition: all 0.4s ease;
    border: 1px solid rgba(0,0,0,0.05);
  }
  .client-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: all 0.4s ease;
  }
  .client-logo:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.08);
    border-color: var(--color-accent);
  }
  .client-logo:hover .client-img {
    filter: grayscale(0%);
    opacity: 1;
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .partner-card {
    padding: 3rem 2rem;
    text-align: center;
    transition: all 0.4s ease;
    border: 1px solid rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .partner-icon {
    width: 60px;
    height: 60px;
    background: rgba(196, 154, 69, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }
  .partner-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    border-color: var(--color-accent);
    background: #fff;
  }
  .partner-card:hover .partner-icon {
    background: var(--color-accent);
    color: #fff;
    transform: rotateY(360deg);
  }
  .partner-card h4 {
    color: var(--color-primary);
    font-size: 1.4rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }
  .partner-card p {
    font-size: 1rem;
    color: #666;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .clients-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .client-logo {
      height: 100px;
      padding: 1.5rem;
    }
    .partners-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof (window as any).gsap !== 'undefined') {
      const gsap = (window as any).gsap;
      
      gsap.from(".gsap-reveal", { y: 50, opacity: 0, duration: 1, ease: "power3.out" });
      gsap.from(".gsap-reveal-delay", { y: 50, opacity: 0, duration: 1, delay: 0.3, ease: "power3.out" });

      gsap.utils.toArray('.gsap-fade-up').forEach((elem: any) => {
        gsap.from(elem, {
          scrollTrigger: { trigger: elem, start: "top bottom-=50" },
          y: 40, opacity: 0, duration: 0.8, ease: "power2.out"
        });
      });

      gsap.from('.gsap-fade', {
        scrollTrigger: { trigger: '.gsap-fade', start: "top bottom-=100" },
        opacity: 0, duration: 1
      });
    }
  });
</script>
