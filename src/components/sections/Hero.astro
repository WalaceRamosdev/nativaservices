---
---
<section id="inicio" class="hero">
  <div
    class="hero-bg"
    style="background-image: linear-gradient(to bottom, rgba(30, 59, 42, 0.6), rgba(18, 33, 25, 0.9)), url('/images/img1.svg');"
  >
  </div>
  <div class="container hero-content">
    <h1 class="logo-text gsap-reveal">
      NATIVA <span class="accent">SERVICE</span>
    </h1>
    <h2 class="gsap-reveal-delay">Governança e Estratégia Ambiental</h2>
    <div class="cta-wrapper gsap-reveal-delay-2">
      <a href="#contato" class="btn">Fale Conosco</a>
      <a href="#sobre" class="btn btn-outline">Conheça a Nativa</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at center, #1e3b2a 0%, #122119 100%);
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    z-index: -1;
  }
  .hero-content { text-align: center; color: var(--color-text-light); }
  .logo-text { font-size: 5rem; letter-spacing: 2px; margin-bottom: 1rem; }
  .accent { color: var(--color-accent); }
  .hero h2 { font-size: 1.8rem; font-weight: 300; margin-bottom: 3rem; }
  .cta-wrapper { display: flex; gap: 1.5rem; justify-content: center; }

  @media (max-width: 900px) {
    .logo-text { font-size: 3rem; }
    .hero h2 { font-size: 1.4rem; }
    .cta-wrapper { flex-direction: column; padding: 0 2rem; }
  }
</style>
