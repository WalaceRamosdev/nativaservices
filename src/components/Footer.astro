        <li><a href="/">Início</a></li>
        <li><a href="/sobre">A Nativa</a></li>
        <li><a href="/servicos">Serviços</a></li>
        <li><a href="/experiencia">Resultados</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contato</h4>
      <ul>
        <li><strong>Telefone:</strong> (62) 98142-3960</li>
        <li><strong>E-mail:</strong> contato@nativaservice.com</li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Dados Cadastrais</h4>
      <ul>
        <li>Nativa Service LTDA</li>
