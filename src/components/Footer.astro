<style>
  .site-footer {
    background-color: var(--color-primary);
    color: var(--color-text-light);
    padding-top: 5rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    margin-bottom: 4rem;
  }
  .footer-col h4 {
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    font-size: 1.2rem;
  }
  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .footer-col a {
    color: var(--color-text-light);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }
  .footer-col a:hover {
    opacity: 1;
    color: var(--color-accent);
  }
  .footer-col li {
    opacity: 0.8;
    line-height: 1.5;
  }
  .logo {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .nativa { color: #fff; }
  .service { color: var(--color-accent); font-weight: 400; }
  .tagline {
    opacity: 0.7;
    font-style: italic;
  }
  .footer-bottom {
    background-color: rgba(0,0,0,0.2);
    padding: 1.5rem 0;
    text-align: center;
    font-size: 0.9rem;
    opacity: 0.7;
  }
</style>
